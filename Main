  }

  function showAnswer(ans, exp) {
    el.a.className = '';
    el.a.textContent = ans || '(geen antwoord)';
    el.exp.textContent = exp || '';
    setStatus('Klaar ✓', 'ready');
    el.abox.classList.add('success');
    setTimeout(function() { el.abox.classList.remove('success'); }, 500);
    showToast('✅ Antwoord!');
  }

  function showError(msg) {
    el.a.className = '';
    el.a.style.cssText = 'color:#F87171;font-size:12px;';
    el.a.textContent = '⚠️ ' + msg;
    setStatus('Fout', 'error');
  }

  function highlight(elem) {
    var all = document.querySelectorAll('.lb-hl');
    for (var i = 0; i < all.length; i++) {
      all[i].classList.remove('lb-hl');
    }
    if (elem) {
      elem.classList.add('lb-hl');
      state.selectedElement = elem;
    }
  }

  // --- QUESTION DETECTOR ---
  function findQuestion() {
    var allText = [];
    var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_ELEMENT, null, false);
    var node;
    while ((node = walker.nextNode())) {
      if (root.contains(node)) continue;
      var tag = node.tagName ? node.tagName.toLowerCase() : '';
      if (tag === 'script' || tag === 'style' || tag === 'noscript' || tag === 'iframe' || tag === 'svg') continue;
     
      var text = (node.innerText || node.textContent || '').trim();
      var rect = node.getBoundingClientRect();
     
      if (text.length > 5 && rect.width > 0 && rect.height > 0 && rect.top < window.innerHeight) {
        allText.push({ text: text, element: node, rect: rect });
      }
    }
   
    var best = null;
    var bestScore = 0;
   
    for (var i = 0; i < allText.length; i++) {
      var item = allText[i];
      var text = item.text;
      var score = 0;
     
      // Question marks
      if (/[？?]/.test(text)) score += 50;
     
      // Dutch question words
      if (/\b(wat|wie|welk|welke|wanneer|waar|waarom|hoe|bereken|uitleg|beschrijf|geef|noem|vergelijk|leg uit|vul|schrijf|bepaal|vind)\b/i.test(text)) score += 40;
     
      // Fill-in-the-blank
      if (/_{2,}|\[.*?\]/.test(text)) score += 45;
     
      // Educational patterns
      if (/afbeelding|figuur|tabel|grafiek|opgave|opdracht|oefening/i.test(text)) score += 30;
     
      // Measurement instruments
      if (/(amperemeter|voltmeter|weegschaal|maatbeker|liniaal|thermometer)/i.test(text)) score += 35;
     
      // Prefix questions
      if (/(voorvoegsel|afkorting|betekenis|eenheid|symbool)/i.test(text)) score += 40;
     
      // French numbers
      if (/\b(un|deux|trois|quatre|cinq|six|sept|huit|neuf|dix|mille|cent|vingt|trente)\b/i.test(text)) score += 30;
     
      // Nederlands XXXX
      if (/nederlands\s+\d+/i.test(text)) score += 50;
     
      // Numbered
      if (/\d+[\)\.]\s/.test(text)) score += 20;
     
      // Math
      if (/[=+\-*/]/.test(text)) score += 15;
     
      // Section labels
      if (/^[A-F][\s\-\:]/m.test(text)) score += 15;
     
      // Length check
      if (text.length > 20 && text.length < 2000) score += 10;
     
      // Position
      if (item.rect.top > 0 && item.rect.top < window.innerHeight * 0.6) score += 15;
     
      if (score > bestScore) {
        bestScore = score;
        best = { text: text, element: item.element, score: score };
      }
    }
   
    return best;
  }

  // --- SMART ANSWER ENGINE ---
  function getSmartAnswer(question) {
    var q = question.toLowerCase();
   
    // PREFIX QUESTIONS
    if (/voorvoegsel|afkorting|betekenis/i.test(q)) {
      var instrument = '';
      var prefix = '';
     
      if (/amperemeter|amper/i.test(q)) {
        instrument = 'amperemeter';
        prefix = 'milli';
        var pData = metricPrefixes[prefix];
        return {
          answer: 'Voorvoegsel: ' + prefix + ', Afkorting: ' + pData.symbol + ', Betekenis: ' + pData.dutch,
          explanation: 'Een milliamperemeter meet stroom in duizendste Ampere. milli = ' + pData.dutch
        };
      }
     
      if (/weegschaal|gram/i.test(q)) {
        instrument = 'weegschaal';
        prefix = 'kilo';
        var pData = metricPrefixes[prefix];
        return {
          answer: 'Voorvoegsel: ' + prefix + ', Afkorting: ' + pData.symbol + ', Betekenis: ' + pData.dutch,
          explanation: 'Een kilogram weegschaal meet gewicht. kilo = ' + pData.dutch
        };
      }
     
      if (/maatbeker|liter/i.test(q)) {
        instrument = 'maatbeker';
        prefix = 'milli';
        var pData = metricPrefixes[prefix];
        return {
          answer: 'Voorvoegsel: ' + prefix + ', Afkorting: ' + pData.symbol + ', Betekenis: ' + pData.dutch,
          explanation: 'Een milliliter maatbeker meet inhoud. milli = ' + pData.dutch
        };
      }
     
      if (/liniaal|meter/i.test(q)) {
        instrument = 'liniaal';
        prefix = 'centi';
        var pData = metricPrefixes[prefix];
        return {
          answer: 'Voorvoegsel: ' + prefix + ', Afkorting: ' + pData.symbol + ', Betekenis: ' + pData.dutch,
          explanation: 'Een centimeter liniaal meet lengte. centi = ' + pData.dutch
        };
      }
    }
   
    // FRENCH NUMBERS
    if (/nederlands\s+\d+/i.test(question)) {
      var match = question.match(/nederlands\s+(\d+)/i);
      if (match) {
        var num = parseInt(match[1]);
        var french = numberToFrench(num);
        return { answer: french, explanation: 'Het getal ' + num + ' in het Frans is "' + french + '".' };
      }
    }
   
    // Check for French in question
    var frenchKeys = Object.keys(frenchNumbers);
    for (var i = 0; i < frenchKeys.length; i++) {
      var french = frenchKeys[i];
      if (q.indexOf(french) !== -1 && french.length > 2) {
        return { answer: french + ' = ' + frenchNumbers[french], explanation: 'Het Franse "' + french + '" betekent ' + frenchNumbers[french] + '.' };
      }
    }
   
    // MATH
    if (/[=+\-*/]/.test(question)) {
      try {
        var nums = question.match(/[\d.]+/g);
        if (nums && nums.length >= 2) {
          var expr = question.match(/[\d+\-*/.]+/);
          if (expr) {
            var result = eval(expr[0]);
            return { answer: String(result), explanation: 'Berekening: ' + expr[0] + ' = ' + result };
          }
        }
      } catch (e) {}
    }
   
    return null;
  }

  // --- NUMBER TO FRENCH ---
  function numberToFrench(num) {
    if (num === 0) return 'zero';
    if (num === 1000) return 'mille';
    if (num === 100) return 'cent';
    if (num === 80) return 'quatre-vingts';
    if (num === 20) return 'vingt';
   
    var units = ['', 'un', 'deux', 'trois', 'quatre', 'cinq', 'six', 'sept', 'huit', 'neuf', 'dix', 'onze', 'douze', 'treize', 'quatorze', 'quinze', 'seize', 'dix-sept', 'dix-huit', 'dix-neuf'];
    var tens = ['', '', 'vingt', 'trente', 'quarante', 'cinquante', 'soixante', 'soixante-dix', 'quatre-vingts', 'quatre-vingt-dix'];
   
    if (num < 20) return units[num];
    if (num < 100) {
      var t = Math.floor(num / 10);
      var u = num % 10;
      if (u === 0) return tens[t];
      return tens[t] + '-' + units[u];
    }
    if (num < 1000) {
      var h = Math.floor(num / 100);
      var r = num % 100;
      var hText = h === 1 ? 'cent' : units[h] + '-cents';
      if (r === 0) return hText.replace('s', '');
      return hText.replace('s', '') + '-' + numberToFrench(r);
    }
   
    return String(num);
  }

  // --- AI ENGINE ---
  function getAIAnswer(question) {
    var prompt = 'Je bent een Nederlandse leraar. Beantwoord deze vraag kort in het NEDERLANDS.\n\nVraag: ' + question + '\n\nRegels:\n1. Antwoord in het NEDERLANDS\n2. Kort en duidelijk\n\nJSON: {"answer":"antwoord","explanation":"uitleg"}';

    return new Promise(function(resolve) {
      var url = 'https://text.pollinations.ai/' + encodeURIComponent(prompt) + '?model=openai&json=true&seed=' + Date.now();
     
      var timeout = setTimeout(function() {
        resolve({ answer: 'AI timeout - probeer opnieuw', explanation: '' });
      }, 15000);
     
      fetch(url).then(function(res) {
        return res.text();
      }).then(function(text) {
        clearTimeout(timeout);
        var match = text.match(/\{[\s\S]*?\}/);
        if (match) {
          try {
            var parsed = JSON.parse(match[0]);
            resolve({ answer: parsed.answer || text.slice(0, 150), explanation: parsed.explanation || '' });
          } catch (e) {
            resolve({ answer: text.slice(0, 150), explanation: '' });
          }
        } else {
          resolve({ answer: text.slice(0, 150), explanation: '' });
        }
      }).catch(function(e) {
        clearTimeout(timeout);
        resolve({ answer: 'AI fout - probeer opnieuw', explanation: '' });
      });
    });
  }

  // --- MAIN PROCESS ---
  async function processQuestion(manual) {
    if (state.processing) return;
    state.processing = true;
    el.ask.disabled = true;

    try {
      var questionText = manual || null;
      var source = 'manual';

      if (!questionText) {
        if (state.selectedElement) {
          questionText = (state.selectedElement.innerText || state.selectedElement.textContent || '').trim();
          source = 'selected';
        } else {
          var found = findQuestion();
          if (found) {
            questionText = found.text;
            highlight(found.element);
            source = 'auto';
          }
        }
      }

      if (!questionText) {
        setStatus('Geen vraag', 'error');
        showToast('❌ Geen vraag. Klik Selecteer of typ handmatig.');
        state.processing = false;
        el.ask.disabled = false;
        return;
      }

      if (questionText === state.lastQuestion && !manual) {
        state.processing = false;
        el.ask.disabled = false;
        return;
      }
      state.lastQuestion = questionText;

      el.q.textContent = questionText.length > 300 ? questionText.slice(0, 300) + '...' : questionText;
      el.q.classList.remove('empty');
      el.badge.textContent = source.toUpperCase();
      el.badge.className = 'lb-badge lb-badge-' + (source === 'auto' ? 'auto' : 'sel');

      showLoading();

      var result = getSmartAnswer(questionText);
      if (!result) {
        result = await getAIAnswer(questionText);
      }

      state.lastAnswer = result.answer;
      showAnswer(result.answer, result.explanation);

    } catch (e) {
      showError('Fout: ' + e.message);
    }

    state.processing = false;
    el.ask.disabled = false;
  }

  // --- CLICK SELECT ---
  function enableClickMode() {
    state.clickMode = true;
    el.sel.classList.add('active');
    el.sel.innerHTML = '🎯 Klik...';
    setStatus('Klik op vraag', 'working');
    document.body.style.cursor = 'crosshair';
    document.addEventListener('mouseover', onHover);
    document.addEventListener('mouseout', onHoverOut);
    document.addEventListener('click', onClickSelect, true);
  }

  function disableClickMode() {
    state.clickMode = false;
    el.sel.classList.remove('active');
    el.sel.innerHTML = '👆 Selecteer';
    setStatus('Klaar', 'ready');
    document.body.style.cursor = '';
    var all = document.querySelectorAll('.lb-hover');
    for (var i = 0; i < all.length; i++) all[i].classList.remove('lb-hover');
    document.removeEventListener('mouseover', onHover);
    document.removeEventListener('mouseout', onHoverOut);
    document.removeEventListener('click', onClickSelect, true);
  }

  function onHover(e) {
    if (!state.clickMode || root.contains(e.target)) return;
    e.target.classList.add('lb-hover');
  }

  function onHoverOut(e) {
    e.target.classList.remove('lb-hover');
  }

  function onClickSelect(e) {
    if (!state.clickMode || root.contains(e.target)) return;
    e.preventDefault();
    e.stopPropagation();
   
    var text = (e.target.innerText || e.target.textContent || '').trim();
    if (text.length < 3) {
      showToast('Geen tekst, probeer ander element.');
      return;
    }
   
    disableClickMode();
    highlight(e.target);
    el.q.textContent = text;
    el.q.classList.remove('empty');
    el.badge.textContent = 'SELECTED';
    el.badge.className = 'lb-badge lb-badge-sel';
    showToast('✅ Geselecteerd!');
    setTimeout(function() { processQuestion(text); }, 200);
  }

  // --- AUTO SCAN ---
  function startAutoScan() {
    stopAutoScan();
    if (CONFIG.autoAnswer) {
      state.autoTimer = setInterval(function() {
        if (state.visible && !state.processing && !state.clickMode) processQuestion();
      }, CONFIG.autoAnswerDelay);
    }
  }

  function stopAutoScan() {
    if (state.autoTimer) {
      clearInterval(state.autoTimer);
      state.autoTimer = null;
    }
  }

  // --- TOGGLE ---
  function toggle() {
    state.visible = !state.visible;
    el.root.classList.toggle('hidden', !state.visible);
    if (state.visible) {
      startAutoScan();
      setTimeout(function() { processQuestion(); }, 400);
    } else {
      stopAutoScan();
      var all = document.querySelectorAll('.lb-hl');
      for (var i = 0; i < all.length; i++) all[i].classList.remove('lb-hl');
      disableClickMode();
    }
  }

  // --- EVENTS ---
  document.addEventListener('keyup', function(e) {
    if (e.code === CONFIG.hotkey) toggle();
  }, true);

  el.close.addEventListener('click', toggle);

  el.ask.addEventListener('click', function() {
    var q = el.input.value.trim();
    var all = document.querySelectorAll('.lb-hl');
    for (var i = 0; i < all.length; i++) all[i].classList.remove('lb-hl');
    state.selectedElement = null;
    processQuestion(q || null);
  });

  el.sel.addEventListener('click', function() {
    if (state.clickMode) disableClickMode();
    else enableClickMode();
  });

  el.clr.addEventListener('click', function() {
    el.input.value = '';
    state.lastQuestion = '';
    state.lastAnswer = '';
    state.selectedElement = null;
    el.q.textContent = 'Geen vraag gevonden...';
    el.q.classList.add('empty');
    el.a.className = 'empty';
    el.a.style.cssText = '';
    el.a.textContent = 'Wachten...';
    el.exp.textContent = '';
    el.badge.textContent = 'AUTO';
    el.badge.className = 'lb-badge lb-badge-auto';
    var all = document.querySelectorAll('.lb-hl');
    for (var i = 0; i < all.length; i++) all[i].classList.remove('lb-hl');
    disableClickMode();
    setStatus('Gewis', 'ready');
    showToast('🗑 Gewist');
  });

  el.input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      var q = el.input.value.trim();
      if (q) {
        var all = document.querySelectorAll('.lb-hl');
        for (var i = 0; i < all.length; i++) all[i].classList.remove('lb-hl');
        state.selectedElement = null;
        processQuestion(q);
      }
    }
  });

  el.chk.addEventListener('change', function(e) {
    CONFIG.autoAnswer = e.target.checked;
    if (CONFIG.autoAnswer) {
      startAutoScan();
      showToast('✅ Auto aan');
    } else {
      stopAutoScan();
      showToast('⏸ Auto uit');
    }
  });

  // --- DRAG ---
  (function() {
    var dragging = false;
    var ox = 0;
    var oy = 0;
    el.header.addEventListener('mousedown', function(e) {
      if (e.target === el.close) return;
      dragging = true;
      var r = el.root.getBoundingClientRect();
      ox = e.clientX - r.left;
      oy = e.clientY - r.top;
      e.preventDefault();
    });
    document.addEventListener('mousemove', function(e) {
      if (!dragging) return;
      var x = Math.max(0, Math.min(e.clientX - ox, innerWidth - el.root.offsetWidth));
      var y = Math.max(0, Math.min(e.clientY - oy, innerHeight - el.root.offsetHeight));
      el.root.style.cssText = 'left:' + x + 'px;top:' + y + 'px;right:auto;';
    });
    document.addEventListener('mouseup', function() { dragging = false; });
  })();

  // --- EXPOSE API ---
  window.__learnbeatAI = {
    toggle: toggle,
    process: processQuestion,
    version: CONFIG.version
  };

  // --- INIT ---
  startAutoScan();
  setStatus('Klaar • Scannen...', 'ready');
  setTimeout(function() { processQuestion(); }, 600);

  console.log('%c🤖 LearnBeat AI Pro v' + CONFIG.version + ' loaded! Press Right Shift to toggle', 'background:linear-gradient(135deg,#6C63FF,#8B5CF6);color:#fff;padding:8px 16px;border-radius:10px;font-weight:bold');

})();
